<%- include('header') %>

<div class="page-body">
    <div class="container-fluid">

        <div class="page-title">
            <div class="row">
                <div class="col-12 col-sm-6">
                    <h3>View Extra Category</h3>
                </div>

                <div class="col-12 col-sm-6">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="/">
                                <i data-feather="home"></i>
                            </a>
                        </li>
                        <li class="breadcrumb-item">Admin</li>
                        <li class="breadcrumb-item active">View Extra Category</li>
                    </ol>
                </div>
            </div>
        </div>

    </div>


    <div class="container-fluid">

        <div class="row">

            <div class="col-sm-12">

                <div class="card">

                    <div class="card-header">
                        <h5>View Extra Category</h5>
                        <span>Use a view <code>table</code></span>
                    </div>


                    <div class="table-responsive">

                        <table class="table table-hover align-middle text-center">

                            <thead>
                                <tr>
                                    <th scope="col" style="width:5%">Sr No</th>
                                    <th scope="col" style="width:15%">Category</th>
                                    <th scope="col" style="width:15%">Sub Category</th>
                                    <th scope="col" style="width:15%">Extra Category</th>
                                    <th scope="col" style="width:35%">Description</th>
                                    <th scope="col" style="width:5%">Status</th>
                                    <th scope="col" style="width:20%">Action</th>
                                </tr>
                            </thead>


                            <tbody>

                                <% extraCategoryData.forEach((extra, index)=> { %>

                                <tr>

                                    <td>
                                        <%= ((currentPage - 1) * limit) + index + 1 %>
                                    </td>


                                    <td>
                                        <%= extra.categoryId ? extra.categoryId.categoryName : '-' %>
                                    </td>


                                    <td>
                                        <%= extra.subCategoryId ? extra.subCategoryId.subCategoryName : '-' %>
                                    </td>


                                    <td>
                                        <%= extra.extraCategoryName %>
                                    </td>


                                    <td>
                                        <%= extra.extraCategoryDescription %>
                                    </td>


                                    <td>

                                        <div class="media-body switch-sm">

                                            <label class="switch">

                                                <input type="checkbox"
                                                <%= extra.status ? "checked" : "" %>
                                                onchange="changeStatus('<%= extra._id %>')">

                                                <span class="switch-state"></span>

                                            </label>

                                        </div>

                                    </td>


                                    <td>

                                        <a href="/extraCategory/edit-extraCategory/<%= extra._id %>"
                                            class="text-warning fs-5 pe-4">

                                            <i class="icofont icofont-ui-edit"></i>

                                        </a>


                                        <a href="/extraCategory/delete-extraCategory/<%= extra._id %>"
                                            onclick="return confirm('Are you sure?')"
                                            class="text-danger fs-5">

                                            <i class="icofont icofont-ui-delete"></i>

                                        </a>

                                    </td>


                                </tr>


                                <% }) %>


                            </tbody>

                        </table>


                        <div class="card-body d-flex justify-content-end">

                            <nav aria-label="Page navigation">

                                <ul class="pagination pagination-primary">


                                    <li class="page-item">
                                        <a class="page-link" href="#">
                                            Previous
                                        </a>
                                    </li>


                                    <li class="page-item <%= currentPage == 1 ? 'active-grey' : '' %>">
                                        <a class="page-link"
                                        href="/extraCategory/view-extraCategory?page=1">
                                            1
                                        </a>
                                    </li>


                                    <li class="page-item <%= currentPage == 2 ? 'active-grey' : '' %>">
                                        <a class="page-link"
                                        href="/extraCategory/view-extraCategory?page=2">
                                            2
                                        </a>
                                    </li>


                                    <li class="page-item <%= currentPage == 3 ? 'active-grey' : '' %>">
                                        <a class="page-link"
                                        href="/extraCategory/view-extraCategory?page=3">
                                            3
                                        </a>
                                    </li>


                                    <li class="page-item">
                                        <a class="page-link" href="#">
                                            Next
                                        </a>
                                    </li>


                                </ul>

                            </nav>

                        </div>


                    </div>

                </div>

            </div>

        </div>

    </div>

</div>



<script>

function changeStatus(id){

    window.location = "/extraCategory/changeStatus/" + id;

}

</script>


<%- include('footer') %>
