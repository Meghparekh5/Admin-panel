<%- include('header') %>
    <div class="page-body">
        <div class="container-fluid">
            <div class="page-title">
                <div class="row">
                    <div class="col-12 col-sm-6">
                        <h3>Category Form </h3>
                    </div>
                    <div class="col-12 col-sm-6">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/"> <i data-feather="home"></i></a></li>
                            <li class="breadcrumb-item"> Category Layout</li>
                            <li class="breadcrumb-item active"> Add Category Forms</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
        <!-- Container-fluid starts-->
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-12 col-xl-6">
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="card">
                                <div class="card-header pb-0">
                                    <h5>Add Category Data </h5>
                                </div>
                                <div class="card-body">
                                    <form action="/category/update-category/<%= category._id %>" method="POST"
                                        enctype="multipart/form-data">
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Category
                                                Name</label>
                                            <input type="text" name="categoryName" class="form-control"
                                                value="<%= category.categoryName %>">
                                        </div>

                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Description</label>
                                            <textarea name="categoryDescription" class="form-control"
                                                rows="5"><%= category.categoryDescription %></textarea>
                                        </div>

                                        <div class="mb-3">

                                            <img src="<%= category.categoryImage %>" width="120"
                                                class="rounded border mb-3">

                                            <input type="file" name="categoryImage" class="form-control">

                                        </div>
                                        <button class="btn btn-primary">
                                            Update Category
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Container-fluid Ends-->
    </div>
    <%- include('footer') %>